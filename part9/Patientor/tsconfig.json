{
  "compilerOptions": {
    "target": "ES6",
    "outDir": "./build/",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}